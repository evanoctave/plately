{
  "expo": {
    "name": "Plately",
    "slug": "plately",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "plately",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0B0E"
    },
    "assetBundlePatterns": [
      "assets/**/*",
      "src/data/**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.evanoctave.plately",
      "buildNumber": "1",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSCameraUsageDescription": "Plately uses the camera so you can photograph your meals and estimate their nutrition on your device.",
        "NSPhotoLibraryUsageDescription": "Plately lets you pick a meal photo from your library to estimate its nutrition.",
        "NSPhotoLibraryAddUsageDescription": "Plately can save a meal photo you capture to your photo library.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.evanoctave.plately",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B0B0E"
      },
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Plately uses the camera so you can photograph your meals and estimate their nutrition on your device."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Plately lets you pick a meal photo from your library to estimate its nutrition."
        }
      ],
      [
        "react-native-fast-tflite",
        {
          "enableCoreMLDelegate": true
        }
      ],
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "5ab9d06c-9a2a-4227-8adb-73b6e33ead49"
      }
    },
    "owner": "producedbyevo"
  }
}
